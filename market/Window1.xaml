<Window x:Class="market.Window1"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="FreshMarket — Welcome"
        Height="620" Width="900"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="Transparent"
        AllowsTransparency="True"
        WindowStyle="None">

    <Window.Resources>
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="#2D6A4F"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontFamily" Value="Segoe UI Semibold"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="Height" Value="50"/>
            <Setter Property="Width" Value="200"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="12"
                                Padding="20,12">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#1B4332"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#081C15"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CardRadio" TargetType="RadioButton">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="0,0,0,16"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="CardBorder"
                                Background="#F0FFF4"
                                BorderBrush="#B7E4C7"
                                BorderThickness="2"
                                CornerRadius="14"
                                Padding="20,16">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Border x:Name="RadioCircle"
                                        Width="22" Height="22"
                                        CornerRadius="11"
                                        BorderBrush="#52B788"
                                        BorderThickness="2"
                                        Background="White"
                                        VerticalAlignment="Center"
                                        Margin="0,0,14,0">
                                    <Ellipse x:Name="RadioDot"
                                             Width="10" Height="10"
                                             Fill="#2D6A4F"
                                             Visibility="Collapsed"
                                             HorizontalAlignment="Center"
                                             VerticalAlignment="Center"/>
                                </Border>

                                <ContentPresenter Grid.Column="1"
                                                  VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="CardBorder" Property="Background" Value="#D8F3DC"/>
                                <Setter TargetName="CardBorder" Property="BorderBrush" Value="#2D6A4F"/>
                                <Setter TargetName="RadioDot" Property="Visibility" Value="Visible"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="CardBorder" Property="Background" Value="#D8F3DC"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border CornerRadius="20"
            ClipToBounds="True">
        <Grid>
            <Border>
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#081C15" Offset="0"/>
                        <GradientStop Color="#1B4332" Offset="0.5"/>
                        <GradientStop Color="#2D6A4F" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
            </Border>

            <Canvas ClipToBounds="True">
                <Ellipse Width="400" Height="400"
                         Canvas.Left="-100" Canvas.Top="-120"
                         Opacity="0.07">
                    <Ellipse.Fill>
                        <RadialGradientBrush>
                            <GradientStop Color="#95D5B2" Offset="0"/>
                            <GradientStop Color="Transparent" Offset="1"/>
                        </RadialGradientBrush>
                    </Ellipse.Fill>
                </Ellipse>
                <Ellipse Width="350" Height="350"
                         Canvas.Right="0" Canvas.Bottom="50"
                         Canvas.Left="600" Canvas.Top="300"
                         Opacity="0.08">
                    <Ellipse.Fill>
                        <RadialGradientBrush>
                            <GradientStop Color="#52B788" Offset="0"/>
                            <GradientStop Color="Transparent" Offset="1"/>
                        </RadialGradientBrush>
                    </Ellipse.Fill>
                </Ellipse>
            </Canvas>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.1*"/>
                    <ColumnDefinition Width="1*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Center"
                            Margin="40,0">

                    <Border Width="90" Height="90"
                            CornerRadius="45"
                            Margin="0,0,0,24"
                            HorizontalAlignment="Center">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#52B788" Offset="0"/>
                                <GradientStop Color="#95D5B2" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <TextBlock Text="🛒"
                                   FontSize="44"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>

                    <TextBlock Text="Celestia"
                               FontFamily="Segoe UI Black"
                               FontSize="46"
                               Foreground="#95D5B2"
                               HorizontalAlignment="Center"
                               LineHeight="46"/>

                    <TextBlock Text="MARKET"
                               FontFamily="Segoe UI Black"
                               FontSize="46"
                               Foreground="White"
                               HorizontalAlignment="Center"
                               
                               Margin="0,0,0,16"/>

                    <Rectangle Height="2" Width="160"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,20">
                        <Rectangle.Fill>
                            <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                                <GradientStop Color="Transparent" Offset="0"/>
                                <GradientStop Color="#52B788" Offset="0.5"/>
                                <GradientStop Color="Transparent" Offset="1"/>
                            </LinearGradientBrush>
                        </Rectangle.Fill>
                    </Rectangle>

                    <TextBlock
                               FontFamily="Segoe UI"
                               FontSize="14"
                               Foreground="#B7E4C7"
                               HorizontalAlignment="Center"
                               TextAlignment="Center"
                               Opacity="0.85"
                               LineHeight="22"/>
                </StackPanel>

                <Border Grid.Column="1"
                        Background="#FAFFF8"
                        CornerRadius="20,0,0,20"
                        Padding="48,50">
                    <StackPanel VerticalAlignment="Center">

                        <TextBlock
                                   FontFamily="Segoe UI Black"
                                   FontSize="30"
                                   Foreground="#1B4332"
                                   Margin="0,0,0,6"><Run Language="ro-ro" Text="WELCOME"/></TextBlock>

                        <TextBlock
                                   FontFamily="Segoe UI"
                                   FontSize="13"
                                   Foreground="#52B788"
                                   Margin="0,0,0,36"/>

                        <RadioButton x:Name="rbComanda"
                                     Style="{StaticResource CardRadio}"
                                     IsChecked="True">
                            <StackPanel>
                                <TextBlock Text="Plasează o comandă"
                                           FontFamily="Segoe UI Semibold"
                                           FontSize="14"
                                           Foreground="#1B4332"/>
                                <TextBlock
                                           FontFamily="Segoe UI"
                                           FontSize="11"
                                           Foreground="#74C69D"
                                           Margin="0,3,0,0"/>
                            </StackPanel>
                        </RadioButton>

                        <RadioButton x:Name="rbProduse"
                                     Style="{StaticResource CardRadio}">
                            <StackPanel>
                                <TextBlock Text=" Vizualizează produsele"
                                           FontFamily="Segoe UI Semibold"
                                           FontSize="14"
                                           Foreground="#1B4332"/>
                                <TextBlock
                                           FontFamily="Segoe UI"
                                           FontSize="11"
                                           Foreground="#74C69D"
                                           Margin="0,3,0,0"/>
                            </StackPanel>
                        </RadioButton>

                        <Rectangle Height="1"
                                   Margin="0,10,0,28"
                                   Opacity="0.3">
                            <Rectangle.Fill>
                                <SolidColorBrush Color="#52B788"/>
                            </Rectangle.Fill>
                        </Rectangle>

                        <Button x:Name="btnIntrare"
                                Content="Intră →"
                                Style="{StaticResource PrimaryButton}"
                                HorizontalAlignment="Stretch"
                                Height="52"
                                Width="Auto"
                                Click="btnIntrare_Click"/>

                        <Button Content="Ieșire"
                                Margin="0,12,0,0"
                                Height="36"
                                Background="Transparent"
                                BorderThickness="0"
                                Foreground="#A0C4AD"
                                FontSize="12"
                                Cursor="Hand"
                                Click="btnClose_Click"/>
                    </StackPanel>
                </Border>
            </Grid>

            <Border Height="40"
                    VerticalAlignment="Top"
                    HorizontalAlignment="Stretch"
                    Background="Transparent"
                    MouseLeftButtonDown="Window_MouseLeftButtonDown"/>
        </Grid>
    </Border>
</Window>