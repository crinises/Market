<Window x:Class="market.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        mc:Ignorable="d"
        Title="Celestia MARKET — Autentificare"
        Height="620" Width="920"
        WindowStartupLocation="CenterScreen"
        Background="Transparent"
        AllowsTransparency="True"
        WindowStyle="None"
        ResizeMode="NoResize">

    <Window.Resources>
        <Style x:Key="AuthInput" TargetType="TextBox">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="BorderBrush" Value="#B7E4C7"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#1B4332"/>
            <Setter Property="Height" Value="44"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="#2D6A4F"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#F0F0F0"/>
                                <Setter Property="BorderBrush" Value="#D0D0D0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="AuthPass" TargetType="PasswordBox">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="BorderBrush" Value="#B7E4C7"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#1B4332"/>
            <Setter Property="Height" Value="44"/>
            <Setter Property="PasswordChar" Value="●"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="PasswordBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="#2D6A4F"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#F0F0F0"/>
                                <Setter Property="BorderBrush" Value="#D0D0D0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryBtn" TargetType="Button">
            <Setter Property="Background" Value="#2D6A4F"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontFamily" Value="Segoe UI Semibold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Height" Value="48"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="10" Padding="20,12">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#1B4332"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#081C15"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="FormLbl" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI Semibold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="#1B4332"/>
            <Setter Property="Margin" Value="0,0,0,5"/>
        </Style>

        <Style x:Key="GreenCheck" TargetType="CheckBox">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="#2D6A4F"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </Window.Resources>

    <Border CornerRadius="18" ClipToBounds="True">
        <Grid>

            <Border IsHitTestVisible="False">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#060F0A" Offset="0"/>
                        <GradientStop Color="#1B4332" Offset="0.6"/>
                        <GradientStop Color="#2D6A4F" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
            </Border>

            <Canvas ClipToBounds="True" IsHitTestVisible="False">
                <Ellipse Width="380" Height="380"
                         Canvas.Left="-80" Canvas.Top="-100" Opacity="0.06">
                    <Ellipse.Fill>
                        <RadialGradientBrush>
                            <GradientStop Color="#95D5B2" Offset="0"/>
                            <GradientStop Color="Transparent" Offset="1"/>
                        </RadialGradientBrush>
                    </Ellipse.Fill>
                </Ellipse>
                <Ellipse Width="300" Height="300"
                         Canvas.Left="680" Canvas.Top="380" Opacity="0.07">
                    <Ellipse.Fill>
                        <RadialGradientBrush>
                            <GradientStop Color="#52B788" Offset="0"/>
                            <GradientStop Color="Transparent" Offset="1"/>
                        </RadialGradientBrush>
                    </Ellipse.Fill>
                </Ellipse>
            </Canvas>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="34"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="Transparent"
                        MouseLeftButtonDown="Window_MouseLeftButtonDown">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                                VerticalAlignment="Center" Margin="0,0,12,0">
                        <Button Content="✕" Width="28" Height="22" FontSize="11"
                                Background="Transparent" Foreground="#74C69D"
                                BorderThickness="0" Cursor="Hand"
                                Click="btnExit_Click"/>
                    </StackPanel>
                </Border>

                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.1*"/>
                        <ColumnDefinition Width="1*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" VerticalAlignment="Center"
                                HorizontalAlignment="Center" Margin="40,0">

                        <TextBlock Text="CELESTIA" FontFamily="Segoe UI Black"
                                   FontSize="42" Foreground="#95D5B2"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="MARKET" FontFamily="Segoe UI Black"
                                   FontSize="42" Foreground="White"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,14"/>

                        <Rectangle Height="2" Width="170"
                                   HorizontalAlignment="Center" Margin="0,0,0,18">
                            <Rectangle.Fill>
                                <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                                    <GradientStop Color="Transparent" Offset="0"/>
                                    <GradientStop Color="#52B788" Offset="0.5"/>
                                    <GradientStop Color="Transparent" Offset="1"/>
                                </LinearGradientBrush>
                            </Rectangle.Fill>
                        </Rectangle>

                        <TextBlock
                                   FontFamily="Segoe UI" FontSize="13"
                                   Foreground="#B7E4C7" HorizontalAlignment="Center"
                                   TextAlignment="Center" Opacity="0.85" LineHeight="24"/>
                    </StackPanel>

                    <Border Grid.Column="1" Background="#FAFFF8"
                            CornerRadius="18,0,0,18" Padding="48,44">
                        <StackPanel VerticalAlignment="Center">

                            <TextBlock Text="Welcome" FontFamily="Segoe UI Black"
                                       FontSize="36" Foreground="#1B4332"
                                       Margin="0,0,0,4"/>
                            <TextBlock
                                       FontFamily="Segoe UI" FontSize="12"
                                       Foreground="#52B788" Margin="0,0,0,32"/>

                            <TextBlock Text="Utilizator" Style="{StaticResource FormLbl}" FontSize="16"/>
                            <TextBox x:Name="txtUser"
                                     Style="{StaticResource AuthInput}"
                                     Margin="0,0,0,18" FontSize="9" Height="62"/>

                            <TextBlock Text="Parolă" Style="{StaticResource FormLbl}" FontSize="16"/>
                            <PasswordBox x:Name="txtPass"
                                         Style="{StaticResource AuthPass}"
                                         Margin="0,0,0,18" FontSize="9" Height="62"/>

                            <Border x:Name="errBorder" Visibility="Collapsed"
                                    Background="#FFF0F0" BorderBrush="#FF6B6B"
                                    BorderThickness="1.5" CornerRadius="8"
                                    Padding="12,8" Margin="0,0,0,14">
                                <TextBlock x:Name="lblErr" Foreground="#C0392B"
                                           FontFamily="Segoe UI" FontSize="12"
                                           TextWrapping="Wrap"/>
                            </Border>

                            <CheckBox x:Name="chkVizitator"
          Content="  Continuă ca vizitator"
          Foreground="#2D6A4F"
          FontFamily="Segoe UI"
          FontSize="13"
          Cursor="Hand"
          Margin="0,0,0,20"
          Checked="ChkVizitator_Changed"
          Unchecked="ChkVizitator_Changed"/>

                            <Button Content="Intră în cont →"
                                    Style="{StaticResource PrimaryBtn}"
                                    HorizontalAlignment="Stretch"
                                    Click="btnLogin_Click"
                                    Margin="0,0,0,20"/>

                            <Rectangle Height="1" Margin="0,0,0,16" Opacity="0.25">
                                <Rectangle.Fill>
                                    <SolidColorBrush Color="#52B788"/>
                                </Rectangle.Fill>
                            </Rectangle>

                            <StackPanel Orientation="Horizontal"
                                        HorizontalAlignment="Center">
                                <TextBlock Text="Nu ai cont? "
                                           FontFamily="Segoe UI" FontSize="12"
                                           Foreground="#74C69D"/>
                                <TextBlock Text="Creează unul acum"
                                           FontFamily="Segoe UI Semibold" FontSize="12"
                                           Foreground="#2D6A4F" Cursor="Hand"
                                           TextDecorations="Underline"
                                           MouseLeftButtonDown="LnkRegister_Click"/>
                            </StackPanel>

                        </StackPanel>
                    </Border>
                </Grid>
            </Grid>

        </Grid>
    </Border>
</Window>