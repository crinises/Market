<Window x:Class="market.RegisterWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        mc:Ignorable="d"
        Title="Celestia MARKET — Înregistrare"
        Height="720" Width="580"
        WindowStartupLocation="CenterScreen"
        Background="Transparent"
        AllowsTransparency="True"
        WindowStyle="None"
        ResizeMode="NoResize">

    <Window.Resources>
        <Style x:Key="RegInput" TargetType="TextBox">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="11,9"/>
            <Setter Property="BorderBrush" Value="#B7E4C7"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#1B4332"/>
            <Setter Property="Height" Value="42"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="9">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="#2D6A4F"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="RegPass" TargetType="PasswordBox">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="11,9"/>
            <Setter Property="BorderBrush" Value="#B7E4C7"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#1B4332"/>
            <Setter Property="Height" Value="42"/>
            <Setter Property="PasswordChar" Value="●"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="PasswordBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="9">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="#2D6A4F"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="Lbl" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI Semibold"/>
            <Setter Property="FontSize" Value="11.5"/>
            <Setter Property="Foreground" Value="#1B4332"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>

        <Style x:Key="RegBtn" TargetType="Button">
            <Setter Property="Background" Value="#2D6A4F"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontFamily" Value="Segoe UI Semibold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Height" Value="46"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="10" Padding="20,10">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#1B4332"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border CornerRadius="18" ClipToBounds="True">
        <Grid>
            <Border>
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#060F0A" Offset="0"/>
                        <GradientStop Color="#1B4332" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
            </Border>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="34"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="Transparent"
                        MouseLeftButtonDown="Window_MouseLeftButtonDown">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                                VerticalAlignment="Center" Margin="0,0,12,0">
                        <Button Content="✕" Width="28" Height="22" FontSize="11"
                                Background="Transparent" Foreground="#74C69D"
                                BorderThickness="0" Cursor="Hand"
                                Click="btnClose_Click"/>
                    </StackPanel>
                </Border>

                <Border Grid.Row="1" Background="#FAFFF8"
                        CornerRadius="16,16,0,0" Margin="20,0,20,0" Padding="40,30">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel>

                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                <TextBlock Text="✦ " Foreground="#52B788"
                                           FontSize="22" VerticalAlignment="Center"/>
                                <TextBlock Text="Cont nou" FontFamily="Segoe UI Black"
                                           FontSize="26" Foreground="#1B4332"/>
                            </StackPanel>
                            <TextBlock
                                       FontFamily="Segoe UI" FontSize="12"
                                       Foreground="#52B788" Margin="0,0,0,26"/>

                            <Grid Margin="0,0,0,14">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="14"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Nume *" Style="{StaticResource Lbl}"/>
                                    <TextBox x:Name="txtNume" Style="{StaticResource RegInput}" Height="52" FontSize="9"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Prenume *" Style="{StaticResource Lbl}"/>
                                    <TextBox x:Name="txtPrenume" Style="{StaticResource RegInput}" Height="53"/>
                                </StackPanel>
                            </Grid>

                            <TextBlock Text="Utilizator (username) *" Style="{StaticResource Lbl}"/>
                            <TextBox x:Name="txtUsername" Style="{StaticResource RegInput}"
                                     Margin="0,0,0,14" Height="52" FontSize="8"/>

                            <Grid Margin="0,0,0,14">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="14"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Parolă *" Style="{StaticResource Lbl}"/>
                                    <PasswordBox x:Name="txtParola"
                                                 Style="{StaticResource RegPass}" Height="54"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Repetă parola *" Style="{StaticResource Lbl}"/>
                                    <PasswordBox x:Name="txtParolaRep"
                                                 Style="{StaticResource RegPass}" Height="52"/>
                                </StackPanel>
                            </Grid>

                            <TextBlock Text="Email *" Style="{StaticResource Lbl}"/>
                            <TextBox x:Name="txtEmail" Style="{StaticResource RegInput}"
                                     Margin="0,0,0,14"
                                     ToolTip="exemplu@domeniu.com" Height="53"/>


                           <TextBlock Text="Nr. telefon *" Style="{StaticResource Lbl}"/>
                            <TextBox x:Name="txtPhone" Style="{StaticResource RegInput}"
                                     Margin="0,0,0,22"
                                     MaxLength="15"
                                     PreviewTextInput="TxtPhone_PreviewTextInput"
                                     ToolTip="Doar cifre" Height="52"/>

                            <Border x:Name="fbBorder" Visibility="Collapsed"
                                    CornerRadius="9" Padding="12,9" Margin="0,0,0,14">
                                <TextBlock x:Name="lblFb" FontFamily="Segoe UI"
                                           FontSize="12" TextWrapping="Wrap"/>
                            </Border>

                            <Button Content="✦  Creează contul"
                                    Style="{StaticResource RegBtn}"
                                    HorizontalAlignment="Stretch"
                                    Click="btnRegister_Click"/>

                            <StackPanel Orientation="Horizontal"
                                        HorizontalAlignment="Center" Margin="0,16,0,0">
                                <TextBlock Text="Ai deja cont? "
                                           FontFamily="Segoe UI" FontSize="12"
                                           Foreground="#74C69D"/>
                                <TextBlock Text="Autentifică-te"
                                           FontFamily="Segoe UI Semibold" FontSize="12"
                                           Foreground="#2D6A4F" Cursor="Hand"
                                           TextDecorations="Underline"
                                           MouseLeftButtonDown="LnkBack_Click"/>
                            </StackPanel>

                        </StackPanel>
                    </ScrollViewer>
                </Border>
            </Grid>
        </Grid>
    </Border>
</Window>