<Window x:Class="market.ProductsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="FreshMarket — Produse"
        Height="680" Width="1050"
        WindowStartupLocation="CenterScreen"
        Background="Transparent"
        AllowsTransparency="True"
        WindowStyle="None"
        ResizeMode="NoResize">

    <Window.Resources>
        <Style TargetType="Menu">
            <Setter Property="Background" Value="#1B4332"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontFamily" Value="Segoe UI Semibold"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
        <Style TargetType="MenuItem">
            <Setter Property="Background" Value="#1B4332"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="14,8"/>
        </Style>

        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="#FAFFF8"/>
            <Setter Property="BorderBrush" Value="#B7E4C7"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="RowBackground" Value="#FAFFF8"/>
            <Setter Property="AlternatingRowBackground" Value="#F0FFF4"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#D8F3DC"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#2D6A4F"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontFamily" Value="Segoe UI Semibold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="BorderThickness" Value="0,0,1,0"/>
            <Setter Property="BorderBrush" Value="#52B788"/>
        </Style>

        <Style x:Key="GreenBtn" TargetType="Button">
            <Setter Property="Background" Value="#2D6A4F"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontFamily" Value="Segoe UI Semibold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8" Padding="16,8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#1B4332"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border CornerRadius="18" ClipToBounds="True">
        <Grid>
            <Border>
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#081C15" Offset="0"/>
                        <GradientStop Color="#1B4332" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
            </Border>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                  
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Height="32" Background="Transparent"
                        MouseLeftButtonDown="Window_MouseLeftButtonDown">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,12,0">
                        <Button Content="✕" Width="28" Height="22" FontSize="12"
                                Background="Transparent" Foreground="#74C69D"
                                BorderThickness="0" Cursor="Hand"
                                Click="btnClose_Click"/>
                    </StackPanel>
                </Border>

                <Grid Grid.Row="1" Margin="24,0,24,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Border Width="56" Height="56" CornerRadius="28" Margin="0,0,16,12">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#52B788" Offset="0"/>
                                <GradientStop Color="#95D5B2" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <TextBlock Text="🛒" FontSize="26"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>

                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Text="Celestia MARKET" FontFamily="Segoe UI Black"
                                   FontSize="22" Foreground="White" />
                        <TextBlock Text="Catalog de produse" FontFamily="Segoe UI"
                                   FontSize="12" Foreground="#74C69D"/>
                    </StackPanel>

                    <Button Grid.Column="2" Content="Plasează Comandă"
                            Style="{StaticResource GreenBtn}"
                            VerticalAlignment="Center"
                            Click="btnOpenOrder_Click"/>
                </Grid>

                <Grid Grid.Row="2" Margin="24,0,24,16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    
                    <Border Grid.Row="0" CornerRadius="10" Margin="0,0,0,12" ClipToBounds="True">
                        <Menu x:Name="mainMenu" Background="#1B4332">

                           
                            <MenuItem Header="Toate produsele" Click="MenuFilter_Click" Tag="Toate"/>

                        
                            <MenuItem Header="Produse alimentare">
                                <MenuItem Header="Produse proaspete">
                                    <MenuItem Header="Fructe" Click="MenuFilter_Click" Tag="Fructe"/>
                                    <MenuItem Header="Legume" Click="MenuFilter_Click" Tag="Legume"/>
                                    <MenuItem Header="Verdețuri" Click="MenuFilter_Click" Tag="Verdețuri"/>
                                </MenuItem>
                                <MenuItem Header="Băuturi">
                                    <MenuItem Header="Băuturi alcoolice" Click="MenuFilter_Click" Tag="Băuturi alcoolice"/>
                                    <MenuItem Header="Băuturi nealcoolice" Click="MenuFilter_Click" Tag="Băuturi nealcoolice"/>
                                    <MenuItem Header="Apă plată" Click="MenuFilter_Click" Tag="Apă plată"/>
                                </MenuItem>
                            </MenuItem>

                            <MenuItem Header="Produse chimice">
                                <MenuItem Header="Produse de îngrijire a părului" Click="MenuFilter_Click" Tag="Îngrijire păr"/>
                                <MenuItem Header="Burete" Click="MenuFilter_Click" Tag="Lavete Burete"/>
                                <MenuItem Header="Produse de îngrijire corporală" Click="MenuFilter_Click" Tag="Îngrijire corporală"/>
                            </MenuItem>

                            <MenuItem Header="Comandă" Click="btnOpenOrder_Click"/>

                            <MenuItem Header="Condiții de livrare" Click="MenuDelivery_Click"/>
                        </Menu>
                    </Border>

                    <Grid Grid.Row="1">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                            <TextBlock Text="Categorie: " Foreground="#74C69D"
                                       FontFamily="Segoe UI" FontSize="12"/>
                            <TextBlock x:Name="lblCurrentFilter" Text="Toate produsele"
                                       Foreground="#95D5B2" FontFamily="Segoe UI Semibold" FontSize="12"/>
                        </StackPanel>

                        <Border Grid.Row="1" CornerRadius="12" ClipToBounds="True"
                                BorderBrush="#52B788" BorderThickness="1">
                            <DataGrid x:Name="dgProducts"
                                      AutoGenerateColumns="False"
                                      IsReadOnly="True"
                                      CanUserReorderColumns="False"
                                      CanUserResizeRows="False"
                                      SelectionMode="Single"
                                      SelectionUnit="FullRow"
                                      HeadersVisibility="Column">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="55"/>
                                    <DataGridTextColumn Header="Produs" Binding="{Binding Name}" Width="200"/>
                                    <DataGridTextColumn Header="Categorie" Binding="{Binding Category}" Width="180"/>
                                    <DataGridTextColumn Header="Preț (lei)" Binding="{Binding Price}" Width="100"/>
                                    <DataGridTextColumn Header="Stoc" Binding="{Binding Stock}" Width="80"/>
                                    <DataGridTextColumn Header="U.M." Binding="{Binding Unit}" Width="*"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Border>
                    </Grid>
                </Grid>

                <Border Grid.Row="3" Background="#0D2B1E" Padding="24,10">
                    <TextBlock
                               Foreground="#52B788" FontFamily="Segoe UI" FontSize="11"
                               HorizontalAlignment="Center"/>
                </Border>
            </Grid>
        </Grid>
    </Border>
</Window>