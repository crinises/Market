<Window x:Class="market.OrderWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="CelestiaMarket — plasează comandă"
        Height="720" Width="960"
        WindowStartupLocation="CenterScreen"
        Background="Transparent"
        AllowsTransparency="True"
        WindowStyle="None"
        ResizeMode="NoResize">

    <Window.Resources>
        <Style x:Key="FormLabel" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI Semibold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="#1B4332"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>

        <Style x:Key="FormInput" TargetType="TextBox">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="BorderBrush" Value="#B7E4C7"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#1B4332"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="#2D6A4F"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="FormCombo" TargetType="ComboBox">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="BorderBrush" Value="#B7E4C7"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#1B4332"/>
            <Setter Property="Height" Value="40"/>
        </Style>

        <Style x:Key="SubmitBtn" TargetType="Button">
            <Setter Property="Background" Value="#2D6A4F"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontFamily" Value="Segoe UI Semibold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Height" Value="48"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="10" Padding="20,12">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#1B4332"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#081C15"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border CornerRadius="18" ClipToBounds="True">
        <Grid>
            <Border>
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#081C15" Offset="0"/>
                        <GradientStop Color="#1B4332" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
            </Border>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="36"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="Transparent"
                        MouseLeftButtonDown="Window_MouseLeftButtonDown">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                                VerticalAlignment="Center" Margin="0,0,12,0">
                        <Button Content="✕" Width="28" Height="22" FontSize="12"
                                Background="Transparent" Foreground="#74C69D"
                                BorderThickness="0" Cursor="Hand"
                                Click="btnClose_Click"/>
                    </StackPanel>
                </Border>

                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="260"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" VerticalAlignment="Center"
                                HorizontalAlignment="Center" Margin="20,0">
                        <Border Width="80" Height="80" CornerRadius="40"
                                HorizontalAlignment="Center" Margin="0,0,0,20">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#52B788" Offset="0"/>
                                    <GradientStop Color="#95D5B2" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <TextBlock Text="" FontSize="38"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>

                        <TextBlock Text="Celestia" FontFamily="Segoe UI Black"
                                   FontSize="36" Foreground="#95D5B2"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="MARKET" FontFamily="Segoe UI Black"
                                   FontSize="36" Foreground="White"
                                   HorizontalAlignment="Center"/>

                        <Rectangle Height="2" Width="130" Margin="0,14,0,14"
                                   HorizontalAlignment="Center">
                            <Rectangle.Fill>
                                <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                                    <GradientStop Color="Transparent" Offset="0"/>
                                    <GradientStop Color="#52B788" Offset="0.5"/>
                                    <GradientStop Color="Transparent" Offset="1"/>
                                </LinearGradientBrush>
                            </Rectangle.Fill>
                        </Rectangle>

                        <TextBlock 
                                   FontFamily="Segoe UI" FontSize="13"
                                   Foreground="#B7E4C7" TextAlignment="Center"
                                   HorizontalAlignment="Center" LineHeight="22" Opacity="0.9"/>

                        <Button Content="← Înapoi la produse"
                                Margin="0,40,0,0"
                                Height="38"
                                Background="Transparent"
                                BorderBrush="#52B788"
                                BorderThickness="1"
                                Foreground="#74C69D"
                                FontFamily="Segoe UI"
                                FontSize="12"
                                Cursor="Hand"
                                Click="btnBack_Click">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="Transparent" BorderBrush="#52B788"
                                            BorderThickness="1" CornerRadius="8" Padding="14,8">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Foreground" Value="White"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </StackPanel>

                    <Border Grid.Column="1" Background="#FAFFF8"
                            CornerRadius="18,0,0,18" Padding="44,36">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel>
                                <TextBlock Text="Plasează o comandă"
                                           FontFamily="Segoe UI Black" FontSize="26"
                                           Foreground="#1B4332" Margin="0,0,0,4"/>
                                <TextBlock Text="Completează toate câmpurile pentru a finaliza comanda"
                                           FontFamily="Segoe UI" FontSize="12"
                                           Foreground="#52B788" Margin="0,0,0,28"/>

                                <Grid Margin="0,0,0,16">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="16"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Nume *" Style="{StaticResource FormLabel}"/>
                                        <TextBox x:Name="txtNume" Style="{StaticResource FormInput}"
                                                 Height="58"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="Prenume *" Style="{StaticResource FormLabel}"/>
                                        <TextBox x:Name="txtPrenume" Style="{StaticResource FormInput}"
                                                 Height="59"/>
                                    </StackPanel>
                                </Grid>

                                <Grid Margin="0,0,0,16">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="16"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Nr. de contact *" Style="{StaticResource FormLabel}"/>
                                        <TextBox x:Name="txtTelefon" Style="{StaticResource FormInput}"
                                                 Height="60"
                                                 PreviewTextInput="TxtTelefon_PreviewTextInput"
                                                 MaxLength="15"
                                                 ToolTip="Introduceți doar cifre (min. 8)"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="Adresă Email *" Style="{StaticResource FormLabel}"/>
                                        <TextBox x:Name="txtEmail" Style="{StaticResource FormInput}"
                                                 Height="56"
                                                 ToolTip="exemplu@domeniu.com"/>
                                    </StackPanel>
                                </Grid>

                                <Grid Margin="0,0,0,16">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="16"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Categorie *" Style="{StaticResource FormLabel}"/>
                                        <ComboBox x:Name="cmbCategorie"
                                                  Style="{StaticResource FormCombo}"
                                                  SelectionChanged="CmbCategorie_SelectionChanged"
                                                  Padding="10,4" Height="60">
                                            <ComboBoxItem Content="-- Selectați categoria --" IsEnabled="False" IsSelected="True"/>
                                            <ComboBoxItem Content="Fructe"/>
                                            <ComboBoxItem Content="Legume"/>
                                            <ComboBoxItem Content="Verdețuri"/>
                                            <ComboBoxItem Content="Băuturi alcoolice"/>
                                            <ComboBoxItem Content="Băuturi nealcoolice"/>
                                            <ComboBoxItem Content="Apă plată"/>
                                            <ComboBoxItem Content="Îngrijire păr"/>
                                            <ComboBoxItem Content="Lavete Burete"/>
                                            <ComboBoxItem Content="Îngrijire corporală"/>
                                        </ComboBox>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="Produs *" Style="{StaticResource FormLabel}"/>
                                        <ComboBox x:Name="cmbProdus"
                                                  Style="{StaticResource FormCombo}"
                                                  Padding="10,4"
                                                  IsEnabled="False" Height="60"/>
                                    </StackPanel>
                                </Grid>

                                <StackPanel Margin="0,0,0,28" HorizontalAlignment="Left" Width="200">
                                    <TextBlock Text="Cantitate *" Style="{StaticResource FormLabel}"/>
                                    <TextBox x:Name="txtCantitate" Style="{StaticResource FormInput}"
                                             Height="62" MaxLength="5"
                                             PreviewTextInput="TxtTelefon_PreviewTextInput"
                                             ToolTip="Introduceți cantitatea dorită" Width="206"/>
                                </StackPanel>

                                <Rectangle Height="1" Margin="0,0,0,24" Opacity="0.3">
                                    <Rectangle.Fill>
                                        <SolidColorBrush Color="#52B788"/>
                                    </Rectangle.Fill>
                                </Rectangle>

                                <Button Content="  Transmite comanda"
                                        Style="{StaticResource SubmitBtn}"
                                        Click="btnSubmit_Click"/>

                                <Border x:Name="feedbackBorder"
                                        Visibility="Collapsed"
                                        CornerRadius="8"
                                        Margin="0,16,0,0"
                                        Padding="14,10">
                                    <TextBlock x:Name="lblFeedback"
                                               FontFamily="Segoe UI"
                                               FontSize="12"
                                               TextWrapping="Wrap"/>
                                </Border>
                            </StackPanel>
                        </ScrollViewer>
                    </Border>
                </Grid>
            </Grid>
        </Grid>
    </Border>
</Window>